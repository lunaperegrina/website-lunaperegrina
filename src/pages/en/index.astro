---
import { getCollection } from "astro:content";
import ArrowCard from "@components/ArrowCard.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE, SOCIALS } from "@consts";
import { useTranslations, toLocalizedPath, type Locale } from "@i18n/utils";
import PageLayout from "@layouts/PageLayout.astro";
import { dateRange } from "@lib/utils";

const locale: Locale = "en";
const t = useTranslations(locale);

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .filter((entry) => entry.id.startsWith(`${locale}/`))
  .sort(
    (a, b) =>
      new Date(b.data.dateStart).valueOf() -
      new Date(a.data.dateStart).valueOf(),
  )
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);
---

<PageLayout title={t("home.meta.title")} description={t("home.meta.description")} locale={locale}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      {t("home.greeting")} <span class="text-xl">🌌</span>
    </h4>
    <div class="space-y-12">
      <section>
        <article class="space-y-4">
          <p class="animate">
            {t("home.intro.1")}
          </p>
          <p class="animate">
            {t("home.intro.2")}
          </p>
          <p class="animate">
            <Link
              href="https://github.com/lunaperegrina/astro-aru"
              aria-label={t("home.astroAruOnGithub")}
              external
            >
              {t("home.astroAruOnGithub")}
            </Link>
            . {t("home.intro.3")}
          </p>
        </article>
      </section>

      <section class="animate">
        <ul class="flex flex-wrap gap-2">
          {
            SOCIALS.map((social) => (
              <li class="flex gap-x-2 text-nowrap">
                <Link
                  href={social.HREF}
                  external
                  aria-label={`${SITE.NAME} on ${social.NAME}`}
                >
                  {social.NAME}
                </Link>
                {"/"}
              </li>
            ))
          }
          <li class="line-clamp-1">
            <Link
              href={`mailto:${SITE.EMAIL}`}
              aria-label={`Email ${SITE.NAME}`}
            >
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">{t("home.latestPosts")}</h5>
          <Link href={toLocalizedPath(locale, "blog")}> {t("home.seeAllPosts")} </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            blog.map((post) => (
              <li>
                <ArrowCard entry={post} locale={locale} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            {t("home.workExperience")}
          </h5>
          <Link href={toLocalizedPath(locale, "work")}> {t("home.seeAllWork")} </Link>
        </div>
        <ul class="flex flex-col space-y-4">
          {
            allwork.map((entry) => (
              <li class="animate border-b border-black/10 dark:border-white/10 py-4 last:border-0">
                <div class="text-sm opacity-75">
                  {dateRange(entry.data.dateStart, locale, entry.data.dateEnd)}
                </div>
                <div class="font-semibold text-black dark:text-white">
                  {entry.data.company}
                </div>
                <div class="text-sm opacity-75">
                  {entry.data.role} · {entry.data.location}
                </div>
                <ul class="mt-2 list-disc pl-5 space-y-1">
                  {entry.data.highlights.slice(0, 2).map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            {t("home.recentProjects")}
          </h5>
          <Link href={toLocalizedPath(locale, "projects")}> {t("home.seeAllProjects")} </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            projects.map((project) => (
              <li>
                <ArrowCard entry={project} locale={locale} />
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
