---
import { type CollectionEntry, getCollection } from "astro:content";
import BackToPrev from "@components/BackToPrev.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { toLocalizedPath, useTranslations, type Locale } from "@i18n/utils";
import { isEntryInLocale, stripLocalePrefixFromSlug } from "@lib/content-localization";
import { readingTime } from "@lib/utils";

const locale: Locale = "en";
const t = useTranslations(locale);

export async function getStaticPaths() {
  const blogLocale: Locale = "en";
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft && isEntryInLocale(post.id, blogLocale))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: stripLocalePrefixFromSlug(post.slug, blogLocale) },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
---

<PageLayout title={post.data.title} description={post.data.description} locale={locale}>
  <Container>
    <div class="animate">
      <BackToPrev href={toLocalizedPath(locale, "blog")}> {t("blog.backToBlog")} </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} locale={locale} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body, locale)}
        </div>
      </div>
      <div class="animate text-2xl font-semibold text-black dark:text-white">
        {post.data.title}
      </div>
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>
