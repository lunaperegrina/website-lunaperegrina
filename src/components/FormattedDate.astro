---
import { getIntlLocale, type Locale } from "@i18n/utils";

interface Props {
  date: Date;
  locale: Locale;
}

const { date, locale } = Astro.props;
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(getIntlLocale(locale), {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
  }
</time>
